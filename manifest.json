{
  "manifest_version": 3,
  "name": "ChatGPT to Anki",
  "version": "0.1.8",
  "description": "Save approved ChatGPT flashcard JSON blocks to Anki via AnkiConnect, with an editable preview dialog, keyboard shortcut, self-healing button, manual paste fallback, optional diagnostics, and post-save edit-feedback copying.",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatGPT to Anki"
  },
  "commands": {
    "open-save-dialog": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "Open the Save latest Anki card dialog"
    }
  }
}